# ============================================================
# Family Accountability — .env.example
# Copy to .env.local and fill in. Do NOT commit .env.local.
# ============================================================

# --- Supabase (NEW project, NOT shared with WebCraft Media) -----------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (OPTIONAL — daily summary falls back to Telegram-only if blank) -
# Leave blank to skip email entirely. Telegram delivers the daily summary
# to both parents' bots — that's enough for V1.
RESEND_API_KEY=
EMAIL_FROM=Family Accountability <noreply@family.webcraftmedia.digital>
EMAIL_TO_AHUVA=ahuvadratler@gmail.com
EMAIL_CC_SHLOIMIE=

# --- AI chat (OPTIONAL — bot does slash-commands-only if blank) -------------
# Kimi is the primary provider. OpenAI is only used if Kimi is missing or fails.
# All slash commands (/today, /streak, /meetings, /addgoal, /freeze, /dashboard)
# work fine without these. The app boots either way.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# --- Telegram — TWO bots, one per parent ------------------------------------
# Each parent has their own bot via BotFather. Webhooks land on
# /api/telegram/webhook/shloimie and /api/telegram/webhook/ahuva.
# Generate a long random TELEGRAM_WEBHOOK_SECRET_* per bot.
TELEGRAM_BOT_TOKEN_SHLOIMIE=
TELEGRAM_BOT_USERNAME_SHLOIMIE=
TELEGRAM_CHAT_ID_SHLOIMIE=
TELEGRAM_WEBHOOK_SECRET_SHLOIMIE=

TELEGRAM_BOT_TOKEN_AHUVA=
TELEGRAM_BOT_USERNAME_AHUVA=
TELEGRAM_CHAT_ID_AHUVA=
TELEGRAM_WEBHOOK_SECRET_AHUVA=

# --- Cron auth --------------------------------------------------------------
CRON_SECRET=

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
KID_NAMES=Menachem,Esther

# Bcrypt hashes — generated via in-app /parent/onboarding wizard.
KID_PINS_HASH_MENACHEM=
KID_PINS_HASH_ESTHER=

# Parent magic-link whitelist (comma-separated)
PARENT_EMAILS=shloimie@example.com,ahuvadratler@gmail.com

# Optional — set to true to bypass dev-only auth checks (NEVER in prod)
SKIP_AUTH=false
