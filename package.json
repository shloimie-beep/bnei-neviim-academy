{
  "name": "bna-website",
  "version": "1.0.0",
  "description": "Bnei Nevi'im Academy Website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "telegram:kimi": "node scripts/telegram-kimi-bridge.mjs",
    "telegram:kimi:start": "powershell -ExecutionPolicy Bypass -File scripts/start-telegram-kimi-bridge.ps1",
    "screenshot": "node tools/screenshot-check.js",
    "format": "prettier --write public/index.html",
    "lighthouse": "lighthouse http://localhost:8080 --output=html --output-path=./lighthouse-report.html"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "lighthouse": "^13.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3"
  }
}
